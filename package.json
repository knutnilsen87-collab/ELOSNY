{
  "name": "evida",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Evida monorepo for juridisk saksarbeidsflate",
  "workspaces": [
    "apps/*",
    "packages/*",
    "services/*"
  ],
  "scripts": {
    "start": "node apps/server/server.js",
    "launch": "powershell -ExecutionPolicy Bypass -File ./start-evida.ps1",
    "test": "node --test tests/*.test.js",
    "smoke": "node scripts/smoke.js",
    "check": "npm test && npm run smoke"
  },
  "engines": {
    "node": ">=24"
  }
}
